generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../ERD.svg"
}

datasource db {
  provider = "postgresql"
}

model CategoriaVehiculo {
  categoriaVehiculoId   Int                    @id @default(autoincrement())
  codigo                String                 @unique
  nombre                String
  parametrosUtilizacion ParametroUtilizacion[]
  vehiculos             Vehiculo[]
}

model Area {
  areaId       Int          @id @default(autoincrement())
  nombre       String
  asignaciones Asignacion[]
}

model Vehiculo {
  vehiculoId                    Int                            @id @default(autoincrement())
  codigoPatrimonio              String                         @unique
  placa                         String                         @unique
  categoriaVehiculoId           Int
  valorNuevo                    Decimal                        @db.Decimal(12, 2)
  valorResidual                 Decimal                        @db.Decimal(12, 2)
  vidaUtilAnios                 Int
  estado                        String
  asignaciones                  Asignacion[]
  conjuntos                     Conjunto[]
  costosFijos                   CostoFijoMensual[]
  costosOperacion               CostoOperacionMensual[]
  costoPromedio                 CostoPromedioAnual?
  inventarios                   InventarioUnidad[]
  llantas                       Llanta[]
  movimientos                   MovimientoDiario[]
  ordenServicios                OrdenServicio[]
  registroMensualMantenimientos RegistroMensualMantenimiento[]
  categoriaVehiculo             CategoriaVehiculo              @relation(fields: [categoriaVehiculoId], references: [categoriaVehiculoId])
  abastecimientos               Abastecimiento[]
}

model Conductor {
  conductorId Int                @id @default(autoincrement())
  documento   String             @unique
  nombre      String
  osActivo    Boolean
  movimientos MovimientoDiario[]
}

model MovimientoDiario {
  movimientoId Int       @id @default(autoincrement())
  vehiculoId   Int
  conductorId  Int
  fecha        DateTime
  kmSalida     Float
  kmLlegada    Float
  horas        Float
  destino      String
  conductor    Conductor @relation(fields: [conductorId], references: [conductorId])
  vehiculo     Vehiculo  @relation(fields: [vehiculoId], references: [vehiculoId])
}

model Asignacion {
  asignacionId Int       @id @default(autoincrement())
  vehiculoId   Int
  areaId       Int
  fechaInicio  DateTime
  fechaFin     DateTime?
  area         Area      @relation(fields: [areaId], references: [areaId])
  vehiculo     Vehiculo  @relation(fields: [vehiculoId], references: [vehiculoId])
}

model InventarioUnidad {
  inventarioId       Int      @id @default(autoincrement())
  vehiculoId         Int
  fecha              DateTime
  lecturaVelocimetro Float
  estadoGeneral      String
  vehiculo           Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])
}

model Conjunto {
  conjuntoId Int      @id @default(autoincrement())
  codigo     String   @unique
  tipo       String
  estado     String
  vehiculoId Int
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])
}

model Llanta {
  llantaId   Int      @id @default(autoincrement())
  codigo     String   @unique
  vehiculoId Int
  dimension  String
  posicion   String
  estado     String
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])
}

model Indicador {
  indicadorId Int    @id @default(autoincrement())
  codigo      String @unique
  nombre      String
  valor       Float
  periodo     String
}

model ParametroUtilizacion {
  parametroId         Int               @id @default(autoincrement())
  categoriaVehiculoId Int
  kmParametro         Float
  horasParametro      Float
  categoriaVehiculo   CategoriaVehiculo @relation(fields: [categoriaVehiculoId], references: [categoriaVehiculoId])
}

model CostoFijoMensual {
  cfmId      Int      @id @default(autoincrement())
  vehiculoId Int
  mesAnio    String
  cfp        Decimal  @db.Decimal(12, 2)
  cfv        Decimal  @db.Decimal(12, 2)
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])
}

model CostoPromedioAnual {
  vehiculoId         Int      @id
  eniaN              Decimal  @db.Decimal(12, 2)
  depreciacion       Decimal  @db.Decimal(12, 2)
  remanenteAcumulado Decimal  @db.Decimal(12, 2)
  costoPromedioAnual Decimal  @db.Decimal(12, 2)
  vehiculo           Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])
}

model CostoOperacionMensual {
  comId      Int      @id @default(autoincrement())
  vehiculoId Int
  mesAnio    String
  kmHoras    Float
  cvv        Decimal  @db.Decimal(12, 2)
  ckv        Decimal  @db.Decimal(12, 2)
  consumo    Decimal  @db.Decimal(12, 2)
  iuv        Decimal  @db.Decimal(12, 2)
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])
}

model Abastecimiento {
  abastecimientoId Int      @id @default(autoincrement())
  numeroOrden      String   @unique
  vehiculoId       Int
  fecha            DateTime
  tipoCombustible  String
  galones          Float
  costo            Decimal  @db.Decimal(12, 2)
  kmVelocimetro    Float
  vehiculo         Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])

  @@map("abastecimiento")
}

model TipoMantenimiento {
  tipoId      Int             @id @default(autoincrement())
  codigo      String          @unique
  descripcion String
  ordenes     OrdenServicio[]
}

model OrdenServicio {
  ordenId      Int                         @id @default(autoincrement())
  numero       String                      @unique
  vehiculoId   Int
  tipoId       Int
  taller       String
  fechaEntrada DateTime
  fechaSalida  DateTime?
  kilometraje  Float
  detalles     DetalleCostoMantenimiento[]
  tipo         TipoMantenimiento           @relation(fields: [tipoId], references: [tipoId])
  vehiculo     Vehiculo                    @relation(fields: [vehiculoId], references: [vehiculoId])
  solicitudes  SolicitudMaterial[]
}

model DetalleCostoMantenimiento {
  detalleId Int           @id @default(autoincrement())
  ordenId   Int
  manoObra  Decimal       @db.Decimal(12, 2)
  repuestos Decimal       @db.Decimal(12, 2)
  otros     Decimal       @db.Decimal(12, 2)
  origen    String
  orden     OrdenServicio @relation(fields: [ordenId], references: [ordenId])
}

model RegistroMensualMantenimiento {
  registroId Int      @id @default(autoincrement())
  vehiculoId Int
  mesAnio    String
  propio     Decimal  @db.Decimal(12, 2)
  terceros   Decimal  @db.Decimal(12, 2)
  vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])
}

model Material {
  materialId Int                @id @default(autoincrement())
  codigo     String             @unique
  nombre     String
  unidad     String
  detalles   DetalleSolicitud[]
}

model SolicitudMaterial {
  solicitudId Int                @id @default(autoincrement())
  numero      String             @unique
  ordenId     Int
  fecha       DateTime
  estado      String
  detalles    DetalleSolicitud[]
  orden       OrdenServicio      @relation(fields: [ordenId], references: [ordenId])
}

model DetalleSolicitud {
  detalleId   Int               @id @default(autoincrement())
  solicitudId Int
  materialId  Int
  cantidad    Float
  material    Material          @relation(fields: [materialId], references: [materialId])
  solicitud   SolicitudMaterial @relation(fields: [solicitudId], references: [solicitudId])
}

model Usuario {
  id       Int      @id @default(autoincrement())
  nombre   String
  email    String   @unique
  password String
  rol      String   @default("Usuario")
}
