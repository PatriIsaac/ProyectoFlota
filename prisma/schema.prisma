generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "../ERD.svg"
}

datasource db {
  provider = "postgresql"
}

enum EstadoVehiculo {
  Operativo
  Mantenimiento
  Inactivo
  DeBaja
}

model Area {
  areaId     Int          @id @default(autoincrement())
  nombre     String
  activo     Boolean      @default(true)
  creadoEn   DateTime     @default(now())
  actualizadoEn DateTime  @updatedAt
  Asignacion Asignacion[]
}

model Asignacion {
  asignacionId Int        @id @default(autoincrement())
  vehiculoId   Int
  areaId       Int
  conductorId  Int?
  fechaInicio  DateTime
  fechaFin     DateTime?
  creadoEn     DateTime   @default(now())
  actualizadoEn DateTime  @updatedAt
  Area         Area       @relation(fields: [areaId], references: [areaId])
  Vehiculo     Vehiculo   @relation(fields: [vehiculoId], references: [vehiculoId])
  Conductor    Conductor? @relation(fields: [conductorId], references: [conductorId])

  @@index([vehiculoId])
  @@index([areaId])
  @@index([conductorId])
}

model CategoriaVehiculo {
  categoriaVehiculoId  Int                    @id @default(autoincrement())
  codigo               String                 @unique
  nombre               String
  activo               Boolean                @default(true)
  creadoEn             DateTime               @default(now())
  actualizadoEn        DateTime               @updatedAt
  ParametroUtilizacion ParametroUtilizacion[]
  Vehiculo             Vehiculo[]
}

model Conductor {
  conductorId       Int                 @id @default(autoincrement())
  documento         String              @unique
  nombre            String
  osActivo          Boolean
  activo            Boolean             @default(true)
  creadoEn          DateTime            @default(now())
  actualizadoEn     DateTime            @updatedAt
  DocumentoPersonal DocumentoPersonal[]
  MovimientoDiario  MovimientoDiario[]
  Asignacion        Asignacion[]
}

model Conjunto {
  conjuntoId Int      @id @default(autoincrement())
  codigo     String   @unique
  tipo       String
  estado     String
  vehiculoId Int
  costo      Float?
  fechaInstalacion DateTime?
  creadoEn   DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  Vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])

  @@index([vehiculoId])
}

model CostoFijoMensual {
  cfmId      Int      @id @default(autoincrement())
  vehiculoId Int
  mesAnio    String
  cfp        Decimal  @db.Decimal(12, 2)
  cfv        Decimal  @db.Decimal(12, 2)
  creadoEn   DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  Vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])

  @@index([vehiculoId])
}

// Control Mensual de Costo Operacional de Vehículo (Formulario MA 122 03 01).
// Los campos siguen la numeración de líneas del formulario del manual F1T02.
model CostoOperacionMensual {
  comId                    Int      @id @default(autoincrement())
  vehiculoId               Int
  mesAnio                  String
  diasUtiles               Int      // (1) días útiles
  km                       Float    // (2) kilometraje del mes
  horas                    Float    // (3) horas de uso del mes
  combustibleGalones       Float    // (4a)
  combustibleCosto         Decimal  @db.Decimal(12, 2) // (4b)
  lubricanteGalones        Float    // (5a)
  lubricanteCosto          Decimal  @db.Decimal(12, 2) // (5b)
  llantasNuevasCosto       Decimal  @db.Decimal(12, 2) // (7a)
  llantasReencauchadasCosto Decimal @db.Decimal(12, 2) // (7b)
  gastosLavado             Decimal  @db.Decimal(12, 2) // (8)
  gastosViaje              Decimal  @db.Decimal(12, 2) // (9)
  cvv                      Decimal  @db.Decimal(12, 2) // (11a) costo variable del vehículo
  ckv                      Decimal  @db.Decimal(12, 2) // (12a) costo por kilómetro
  consumo                  Decimal  @db.Decimal(12, 2) // (13a) IA122 01
  iuv                      Decimal  @db.Decimal(12, 2) // (14c) IA122 03
  creadoEn                 DateTime @default(now())
  actualizadoEn            DateTime @updatedAt
  Vehiculo                 Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])

  @@index([vehiculoId])
}

model CostoPromedioAnual {
  vehiculoId         Int      @id
  eniaN              Decimal  @db.Decimal(12, 2)
  depreciacion       Decimal  @db.Decimal(12, 2)
  remanenteAcumulado Decimal  @db.Decimal(12, 2)
  costoPromedioAnual Decimal  @db.Decimal(12, 2)
  creadoEn           DateTime @default(now())
  actualizadoEn      DateTime @updatedAt
  Vehiculo           Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])
}

model DetalleCostoMantenimiento {
  detalleId     Int           @id @default(autoincrement())
  ordenId       Int
  manoObra      Decimal       @db.Decimal(12, 2)
  repuestos     Decimal       @db.Decimal(12, 2)
  otros         Decimal       @db.Decimal(12, 2)
  origen        String
  creadoEn      DateTime      @default(now())
  actualizadoEn DateTime      @updatedAt
  OrdenServicio OrdenServicio @relation(fields: [ordenId], references: [ordenId])

  @@index([ordenId])
}

model DetalleSolicitud {
  detalleId         Int               @id @default(autoincrement())
  solicitudId       Int
  materialId        Int
  cantidad          Float
  creadoEn          DateTime          @default(now())
  actualizadoEn     DateTime          @updatedAt
  Material          Material          @relation(fields: [materialId], references: [materialId])
  SolicitudMaterial SolicitudMaterial @relation(fields: [solicitudId], references: [solicitudId])

  @@index([solicitudId])
  @@index([materialId])
}

model DocumentoPersonal {
  documentoId Int       @id @default(autoincrement())
  conductorId Int
  tipo        String
  vigencia    DateTime
  fechaSubida DateTime  @default(now())
  archivoUrl  String?
  nombreArchivo String?
  creadoEn    DateTime  @default(now())
  actualizadoEn DateTime @updatedAt
  Conductor   Conductor @relation(fields: [conductorId], references: [conductorId])

  @@index([conductorId])
}

model Indicador {
  indicadorId   Int      @id @default(autoincrement())
  codigo        String   @unique
  nombre        String
  valor         Float
  periodo       String
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
}

model InventarioUnidad {
  inventarioId       Int      @id @default(autoincrement())
  vehiculoId         Int
  fecha              DateTime
  kmHorasLectura     Float
  estadoGeneral      String
  observaciones      String?
  creadoEn           DateTime @default(now())
  actualizadoEn      DateTime @updatedAt
  Vehiculo           Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])

  @@index([vehiculoId])
}

model Llanta {
  llantaId   Int      @id @default(autoincrement())
  codigo     String   @unique
  vehiculoId Int
  dimension  String
  posicion   String
  estado     String
  costo      Float?
  creadoEn   DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  Vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])

  @@index([vehiculoId])
}

model Material {
  materialId       Int                @id @default(autoincrement())
  codigo           String             @unique
  nombre           String
  unidad           String
  stockActual      Float              @default(0)
  stockMinimo      Float              @default(0)
  costoUnitario    Float              @default(0)
  activo           Boolean            @default(true)
  creadoEn         DateTime           @default(now())
  actualizadoEn    DateTime           @updatedAt
  DetalleSolicitud DetalleSolicitud[]
}

model MovimientoDiario {
  movimientoId  Int       @id @default(autoincrement())
  vehiculoId    Int
  conductorId   Int
  fecha         DateTime
  kmSalida      Float
  kmLlegada     Float
  horas         Float
  destino       String
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  Conductor     Conductor @relation(fields: [conductorId], references: [conductorId])
  Vehiculo      Vehiculo  @relation(fields: [vehiculoId], references: [vehiculoId])

  @@index([vehiculoId])
  @@index([conductorId])
}

// MA 122 02 02 - Autorización de Servicio Externo (cuando la orden se atiende en taller de terceros).
model AutorizacionServicioExterno {
  autorizacionId     Int           @id @default(autoincrement())
  numero             String        @unique
  ordenId            Int
  fechaEntrada       DateTime
  fechaSalida        DateTime?
  valorPresupuestado Decimal       @db.Decimal(12, 2)
  nombreResponsable  String
  fechaAprobacion    DateTime?
  creadoEn           DateTime      @default(now())
  actualizadoEn      DateTime      @updatedAt
  OrdenServicio      OrdenServicio @relation(fields: [ordenId], references: [ordenId])

  @@index([ordenId])
}

// MA 122 02 04 - Tarjeta de Mano de Obra (horas de cada mecánico por orden de servicio).
model TarjetaManoObra {
  tarjetaId       Int           @id @default(autoincrement())
  ordenId         Int
  mecanicoNombre  String
  fecha           DateTime
  codigoServicio  String
  horaInicio      DateTime
  horaFin         DateTime
  tiempoUtilizado Float
  creadoEn        DateTime      @default(now())
  actualizadoEn   DateTime      @updatedAt
  OrdenServicio   OrdenServicio @relation(fields: [ordenId], references: [ordenId])

  @@index([ordenId])
}

model OrdenServicio {
  ordenId                     Int                            @id @default(autoincrement())
  numero                      String                         @unique
  vehiculoId                  Int
  tipoId                      Int
  tallerId                    Int
  fechaEntrada                DateTime
  fechaSalida                 DateTime?
  kilometraje                 Float
  activo                      Boolean                        @default(true)
  creadoEn                    DateTime                       @default(now())
  actualizadoEn               DateTime                       @updatedAt
  AutorizacionServicioExterno AutorizacionServicioExterno[]
  DetalleCostoMantenimiento   DetalleCostoMantenimiento[]
  TarjetaManoObra             TarjetaManoObra[]
  TipoMantenimiento           TipoMantenimiento              @relation(fields: [tipoId], references: [tipoId])
  Taller                      Taller                         @relation(fields: [tallerId], references: [tallerId])
  Vehiculo                    Vehiculo                       @relation(fields: [vehiculoId], references: [vehiculoId])
  SolicitudMaterial            SolicitudMaterial[]

  @@index([vehiculoId])
  @@index([tallerId])
}

model ParametroUtilizacion {
  parametroId         Int               @id @default(autoincrement())
  categoriaVehiculoId Int
  kmParametro         Float
  horasParametro      Float
  creadoEn            DateTime          @default(now())
  actualizadoEn       DateTime          @updatedAt
  CategoriaVehiculo   CategoriaVehiculo @relation(fields: [categoriaVehiculoId], references: [categoriaVehiculoId])
}

model RegistroMensualMantenimiento {
  registroId Int      @id @default(autoincrement())
  vehiculoId Int
  mesAnio    String
  propio     Decimal  @db.Decimal(12, 2)
  terceros   Decimal  @db.Decimal(12, 2)
  creadoEn   DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  Vehiculo   Vehiculo @relation(fields: [vehiculoId], references: [vehiculoId])

  @@index([vehiculoId])
}

model Rol {
  rolId         Int       @id @default(autoincrement())
  nombre        String    @unique
  descripcion   String
  estado        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
  Usuario       Usuario[]
}

model Servicentro {
  servicentroId  Int              @id @default(autoincrement())
  nombre         String
  ruc            String           @unique
  direccion      String
  telefono       String
  estado         Boolean          @default(true)
  creadoEn       DateTime         @default(now())
  actualizadoEn  DateTime         @updatedAt
  Abastecimiento Abastecimiento[]
}

model SolicitudMaterial {
  solicitudId      Int                @id @default(autoincrement())
  numero           String             @unique
  ordenId          Int
  fecha            DateTime
  estado           String
  creadoEn         DateTime           @default(now())
  actualizadoEn    DateTime           @updatedAt
  DetalleSolicitud DetalleSolicitud[]
  OrdenServicio    OrdenServicio      @relation(fields: [ordenId], references: [ordenId])

  @@index([ordenId])
}

model Taller {
  tallerId      Int             @id @default(autoincrement())
  nombre        String
  ruc           String          @unique
  direccion     String
  telefono      String
  estado        Boolean         @default(true)
  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime        @updatedAt
  OrdenServicio OrdenServicio[]
}

model TipoMantenimiento {
  tipoId        Int             @id @default(autoincrement())
  codigo        String          @unique
  descripcion   String
  activo        Boolean         @default(true)
  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime        @updatedAt
  OrdenServicio OrdenServicio[]
}

model Usuario {
  usuarioId     Int      @id @default(autoincrement())
  nombres       String
  apellidos     String
  email         String   @unique
  password      String
  rolId         Int
  estado        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  Rol           Rol      @relation(fields: [rolId], references: [rolId])
}

model Vehiculo {
  vehiculoId                   Int                            @id @default(autoincrement())
  codigoPatrimonio             String                         @unique
  placa                        String                         @unique
  categoriaVehiculoId          Int
  valorNuevo                   Decimal                        @db.Decimal(12, 2)
  valorResidual                Decimal                        @db.Decimal(12, 2)
  vidaUtilAnios                Int
  estado                       EstadoVehiculo                 @default(Operativo)
  activo                       Boolean                        @default(true)
  creadoEn                     DateTime                       @default(now())
  actualizadoEn                DateTime                       @updatedAt
  Asignacion                   Asignacion[]
  Conjunto                     Conjunto[]
  CostoFijoMensual             CostoFijoMensual[]
  CostoOperacionMensual        CostoOperacionMensual[]
  CostoPromedioAnual           CostoPromedioAnual?
  InventarioUnidad             InventarioUnidad[]
  Llanta                       Llanta[]
  MovimientoDiario              MovimientoDiario[]
  OrdenServicio                OrdenServicio[]
  RegistroMensualMantenimiento RegistroMensualMantenimiento[]
  CategoriaVehiculo            CategoriaVehiculo              @relation(fields: [categoriaVehiculoId], references: [categoriaVehiculoId])
  Abastecimiento                Abastecimiento[]
}

model Abastecimiento {
  abastecimientoId Int         @id @default(autoincrement())
  numeroOrden      String      @unique
  vehiculoId       Int
  servicentroId    Int
  fecha            DateTime
  tipoCombustible  String
  galones          Float
  costo            Decimal     @db.Decimal(12, 2)
  kmVelocimetro    Float
  activo           Boolean     @default(true)
  creadoEn         DateTime    @default(now())
  actualizadoEn    DateTime    @updatedAt
  Vehiculo         Vehiculo    @relation(fields: [vehiculoId], references: [vehiculoId])
  Servicentro      Servicentro @relation(fields: [servicentroId], references: [servicentroId])

  @@index([vehiculoId])
  @@index([servicentroId])
}
